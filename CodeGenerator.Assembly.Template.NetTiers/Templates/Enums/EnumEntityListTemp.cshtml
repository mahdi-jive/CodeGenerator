@using CodeGenerator.Assembly.Template.NetTiers.Extensions
@using System.Text.RegularExpressions
@model  CodeGenerator.Assembly.Template.NetTiers.TemplateModels.Enums.EnumEntityListTempModel
@{

	var summaryText = string.IsNullOrEmpty(Model.TableEnum.Description)
		? $"An enum representation of the '{Model.TableEnum.Name}' table. [No description found in the database]"
		: Model.TableEnum.Description;
}

using System;

namespace Behsaz.Entities
{
	/// <summary>
	/// @summaryText
	/// </summary>
	/// <remark>this enumeration contains the items contained in the table TBASBank</remark>
	[Serializable]
	public enum @(Model.TableEnum.NamePascal)List
	{
@foreach (var item in Model.Items)
{
@:		/// <summary>
@:		/// @item.Title
@:		/// </summary>
@:		[EnumTextValue(@@"@item.Title")]
@:		@item.Name = @item.Id,
}
	}
}
