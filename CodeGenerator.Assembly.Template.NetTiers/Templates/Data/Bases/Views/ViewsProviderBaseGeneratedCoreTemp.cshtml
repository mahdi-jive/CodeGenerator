		protected VList<@(Model.View.NamePascal)> Fill(IDataReader reader, VList<@(Model.View.NamePascal)> rows, int start, int pageLength)
		{
			int recordnum = 0;
			while (reader.Read() && (pageLength != 0))
			{
				if(recordnum >= start)
