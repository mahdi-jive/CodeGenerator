using System;
using System.ComponentModel;

namespace Behsaz.Entities
{
	/// <summary>
	///		The data structure representation of the '@(Model.Table.Name)' table via interface.
	/// </summary>
	/// <remarks>
	/// 	This struct is generated by a tool and should never be modified.
	/// </remarks>
	public interface I@(Model.Table.NamePascal)
	{
		/// <summary>			
		/// @Model.PrimaryKey.Name : @Model.PrimaryKey.Description?.Replace("\r", "").Replace("\n","\n			///")
		/// </summary>
		/// <remarks>Member of the primary key of the underlying table "@(Model.Table.Name)"</remarks>
		@(Model.PrimaryKey.DataType.SystemType)@(Model.PrimaryKey.IsNullable && Model.PrimaryKey.DataType.SystemType!="System.String" ? "?":"") @(Model.PrimaryKey.NamePascal) { get; set; }
				
	@if (!Model.PrimaryKey.IsIdentity)
{
@:		/// <summary>
@:		/// keep a copy of the original so it can be used for editable primary keys.
@:		/// </summary>
@:		System.Int32 OriginalId { get; set; }
}	
			
		
		
		@foreach (var item in Model.ColumnsWithoutPK)
{
	var isNullable = item.IsNullable && item.DataType.SystemType != "System.String" && item.DataType.SystemType != "System.Byte[]";
@:		/// <summary>			
@:		/// @item.Name : @item.Description?.Replace("\r", "").Replace("\n","\n			///")
@:		/// </summary>
@:		@(item.DataType.SystemType)@(isNullable ? "?":"") @(item.NamePascal) { get; set; }
@:		

}
		/// <summary>
		/// Creates a new object that is a copy of the current instance.
		/// </summary>
		/// <returns>A new object that is a copy of this instance.</returns>
		System.Object Clone();
		
		#region Data Properties

@foreach (var item in Model.ReferencedBy)
{	
@:
@:		/// <summary>
@:		///	Holds a collection of entity objects
@:		///	which are related to this object through the relation _@(item.TableNameCamel)@(item.ColumnNamePascal)
@:		/// </summary>	
@:		TList<@(item.TableNamePascal)> @(item.TableNamePascal)Collection {  get;  set;}	
@:
}
		#endregion Data Properties
	}
}
