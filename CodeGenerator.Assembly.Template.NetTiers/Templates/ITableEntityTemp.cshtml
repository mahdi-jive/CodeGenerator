@using CodeGenerator.Assembly.Template.NetTiers.Extensions
@using System.Text.RegularExpressions
@model CodeGenerator.Assembly.Template.NetTiers.Model.DatabaseInfo.Table.ITable
@{

    var summaryText = string.IsNullOrEmpty(Model.Description)
        ? $"An object representation of the '{Model.Name}' table. [No description found in the database]"
        : Model.Description;

    var columns = (await Model.Columns).DistinctBy(q=>q.Name);
    var referencedBy = (await Model.ReferencedBy).OrderBy(q => q.TableName);
    var primaryKey = columns.FirstOrDefault(q => q.IsPrimaryKey);
    if (primaryKey == null)
    {
        throw new NullReferenceException(Model.Name);
    }
}
using System;
using System.ComponentModel;

namespace Behsaz.Entities
{
	/// <summary>
	///		The data structure representation of the '@(Model.Name)' table via interface.
	/// </summary>
	/// <remarks>
	/// 	This struct is generated by a tool and should never be modified.
	/// </remarks>
	public interface I@(Model.NamePascal)
	{
		/// <summary>			
		/// @primaryKey.Name : @primaryKey.Description?.Replace("\r", "").Replace("\n","\n			///")
		/// </summary>
		/// <remarks>Member of the primary key of the underlying table "@(Model.Name)"</remarks>
		@(primaryKey.DataType.SystemType)@(primaryKey.IsNullable && primaryKey.DataType.SystemType!="System.String" ? "?":"") @(primaryKey.NamePascal) { get; set; }
				
	@if (!primaryKey.IsIdentity)
{
@:		/// <summary>
@:		/// keep a copy of the original so it can be used for editable primary keys.
@:		/// </summary>
@:		System.Int32 OriginalId { get; set; }
}	
			
		
		
		@foreach (var item in columns.Where(c=>!c.IsPrimaryKey))
{
	var isNullable = item.IsNullable && item.DataType.SystemType != "System.String" && item.DataType.SystemType != "System.Byte[]";
@:		/// <summary>			
@:		/// @item.Name : @item.Description?.Replace("\r", "").Replace("\n","\n			///")
@:		/// </summary>
@:		@(item.DataType.SystemType)@(isNullable ? "?":"") @(item.NamePascal) { get; set; }
@:		

}
		/// <summary>
		/// Creates a new object that is a copy of the current instance.
		/// </summary>
		/// <returns>A new object that is a copy of this instance.</returns>
		System.Object Clone();
		
		#region Data Properties

@foreach (var item in referencedBy)
{	
@:
@:		/// <summary>
@:		///	Holds a collection of entity objects
@:		///	which are related to this object through the relation _@(item.TableNameCamel)@(item.ColumnNamePascal)
@:		/// </summary>	
@:		TList<@(item.TableNamePascal)> @(item.TableNamePascal)Collection {  get;  set;}	
@:
}
		#endregion Data Properties
	}
}
